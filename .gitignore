# =====================================================
# Cenix Portfolio — .gitignore
# Tracks: source code, markdown content, design tokens.
# Ignores: secrets, build output, machine-local state.
# =====================================================

# Environment / credentials (SFTP password lives here — NEVER commit)
.env
.env.*
!.env.example

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs (regenerated by `npm run build`)
dist/
build/
.astro/
.cache/

# OS / Editor noise
.DS_Store
._.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Obsidian — keep vault config, ignore per-machine state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Deployment artifacts
.deploy/
deploy.log

# Pre-build symlinks under public/ (regenerated by scripts/link-assets.mjs)
public/portfolio
public/images
public/logos
public/blog
