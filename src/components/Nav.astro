---
interface Props {
  activeNav?: 'home' | 'about' | 'portfolio' | 'blog' | 'contact';
}

const { activeNav = 'home' } = Astro.props;

// On non-home pages, anchor links must point back to the home route
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
const base = isHome ? '' : '/';

const links: Array<{ id: 'home' | 'about' | 'portfolio' | 'blog' | 'contact'; label: string; href: string }> = [
  { id: 'home',      label: 'Home',      href: `${base}#home` },
  { id: 'about',     label: 'About Me',  href: `${base}#about` },
  { id: 'portfolio', label: 'Portfolio', href: `${base}#portfolio` },
  { id: 'blog',      label: 'Blog',      href: `${base}#blog` },
  { id: 'contact',   label: 'Contact',   href: `${base}#contact` },
];
---

<header class="nav" id="nav">
  <div class="nav-container">
    <a href="/" class="nav-logo" aria-label="Cenix home">
      <img src="/images/cenix-logo.png" alt="Cenix" class="nav-logo-img" />
    </a>

    <nav class="nav-menu" id="nav-menu" aria-label="Primary">
      {links.map((link, i) => (
        <a href={link.href} class={`nav-link ${activeNav === link.id ? 'active' : ''}`}>
          <span class="slide-text nav-link-label">
            <span class="slide-text-row">{link.label}</span>
            <span class="slide-text-row" aria-hidden="true">{link.label}</span>
          </span>
          <sup class="nav-link-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</sup>
        </a>
      ))}
    </nav>

    <div class="nav-contact">
      <div class="nav-contact-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.72 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0122 16.92z" />
        </svg>
      </div>
      <div class="nav-contact-text">
        <span class="nav-contact-label">Email Me</span>
        <span class="nav-contact-value">cenix@imcenix.com</span>
      </div>
    </div>

    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>
