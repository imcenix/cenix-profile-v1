---
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import {
  parseH1Sections,
  parseExperience,
  parseProjects,
  inlineMarkdown,
  renderParagraphs,
} from '../utils/parseAbout';

// ---- Load free-form markdown sources ----
const all = await getCollection('about-me');
const norm = (s: string) => s.toLowerCase().replace(/[\s_-]+/g, '');
const findByName = (name: string) => all.find((e) => norm(e.id) === norm(name));

const aboutMeEntry    = findByName('About Me');
const experienceEntry = findByName('Experience');
const projectsEntry   = findByName('Projects');

// ---- About Me sections ----
const aboutSections = aboutMeEntry ? parseH1Sections(aboutMeEntry.body ?? '') : [];
const shortBio = aboutSections.find((s) => /^short version$/i.test(s.title))?.content ?? '';
const fullBio  = aboutSections.find((s) => /^full version$/i.test(s.title))?.content ?? '';
const shortBioHtml = renderParagraphs(shortBio);
const fullBioHtml  = renderParagraphs(fullBio || shortBio);

// ---- Personal info (CV section 2 — phone intentionally omitted) ----
const personalInfo = [
  { label: 'Nationality', value: 'Vietnamese' },
  { label: 'Email',       value: 'cenix@imcenix.com', href: 'mailto:cenix@imcenix.com' },
  { label: 'Birthday',    value: 'February 06, 1985' },
];

// ---- Company logos (read from assets/about-me/logos/) ----
let logos: string[] = [];
try {
  const logoDir = path.resolve('./assets/about-me/logos');
  if (fs.existsSync(logoDir)) {
    logos = fs.readdirSync(logoDir)
      .filter((f) => /\.(png|jpg|jpeg|svg|webp)$/i.test(f))
      .sort();
  }
} catch {
  /* ignore — logos optional */
}

// ---- Experience + Projects ----
// Names to hide from the grid (kept in the markdown for the record, just
// not shown — helps avoid awkward odd rows on the home page).
const HIDDEN_EXPERIENCE = ['NHA DEP MAGAZINE'];
const HIDDEN_PROJECTS   = ['Triip.me'];

const experience = experienceEntry
  ? parseExperience(experienceEntry.body ?? '')
      .filter((e) => !HIDDEN_EXPERIENCE.some((h) => h.toLowerCase() === e.company.toLowerCase()))
  : [];

const projects = projectsEntry
  ? parseProjects(projectsEntry.body ?? '')
      .filter((p) => !HIDDEN_PROJECTS.some((h) => h.toLowerCase() === p.name.toLowerCase()))
  : [];

// Stable IDs for modal targeting
const slugify = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
---

<section id="about" class="section section-dark about-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">About Me</span>
      <h2 class="section-title">Two decades of brand &amp; visual leadership across Vietnam's biggest names.</h2>
    </div>

    <!-- ===== 2-COLUMN: Short bio + Info ===== -->
    <div class="about-top">
      <div class="about-bio">
        {shortBioHtml && <div set:html={shortBioHtml} />}
        {fullBio && (
          <button type="button" class="btn btn-primary about-more" data-modal="bio-modal">
            More Information
            <span class="btn-arrow" aria-hidden="true">→</span>
          </button>
        )}
      </div>

      <aside class="about-info">
        <h3 class="about-info-title">Information</h3>
        <dl class="about-info-list">
          {personalInfo.map((item) => (
            <div class="about-info-row">
              <dt>{item.label}</dt>
              <dd>
                {item.href
                  ? <a href={item.href}>{item.value}</a>
                  : item.value}
              </dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </div>

  <!-- ===== Logo marquee (full-bleed) ===== -->
  {logos.length > 0 ? (
    <div class="logo-marquee" aria-label="Companies I've worked with">
      <div class="logo-marquee-track">
        {[...logos, ...logos].map((file) => (
          <img
            src={`/logos/${file}`}
            alt={file.replace(/\.[^.]+$/, '').replace(/[-_]/g, ' ')}
            class="logo-marquee-item"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  ) : (
    <div class="container logo-marquee-empty">
      <p>
        <span class="placeholder-tag">No logos yet</span>
        Drop company logo files into <code>assets/about-me/logos/</code> and they'll appear here as a continuous marquee.
      </p>
    </div>
  )}

  <div class="container">
    <!-- ===== Experience grid ===== -->
    {experience.length > 0 && (
      <div class="about-block">
        <h3 class="about-subhead">
          <span class="about-subhead-mark" aria-hidden="true">✦</span>
          Experience
        </h3>

        <div class="card-grid">
          {experience.map((job) => {
            const modalId = `exp-${slugify(job.company)}`;
            return (
              <button type="button" class="card" data-modal={modalId}>
                <span class="card-period">{job.period}</span>
                <h4 class="card-title">{job.company}</h4>
                <p class="card-subtitle">{job.position}</p>
                <span class="card-cta" aria-hidden="true">View details →</span>
              </button>
            );
          })}
        </div>
      </div>
    )}

    <!-- ===== Side Projects grid ===== -->
    {projects.length > 0 && (
      <div class="about-block">
        <h3 class="about-subhead">
          <span class="about-subhead-mark" aria-hidden="true">✦</span>
          Side Projects
        </h3>

        <div class="card-grid">
          {projects.map((proj) => {
            const modalId = `proj-${slugify(proj.name)}`;
            return (
              <button type="button" class="card" data-modal={modalId}>
                {proj.year && <span class="card-period">{proj.year}</span>}
                <h4 class="card-title">{proj.name}</h4>
                {proj.subtitle && <p class="card-subtitle">{proj.subtitle}</p>}
                <span class="card-cta" aria-hidden="true">View details →</span>
              </button>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>

<!-- ===== Modal dialogs (rendered once, outside the section flow) ===== -->

<!-- Bio modal -->
{fullBio && (
  <dialog class="modal" id="bio-modal">
    <div class="modal-inner">
      <button type="button" class="modal-close" aria-label="Close">×</button>
      <div class="modal-body">
        <span class="modal-eyebrow">About Me</span>
        <h3 class="modal-title">Full bio</h3>
        <div class="modal-prose" set:html={fullBioHtml} />
      </div>
    </div>
  </dialog>
)}

<!-- Experience modals -->
{experience.map((job) => {
  const modalId = `exp-${slugify(job.company)}`;
  return (
    <dialog class="modal" id={modalId}>
      <div class="modal-inner">
        <button type="button" class="modal-close" aria-label="Close">×</button>
        <div class="modal-body">
          <span class="modal-eyebrow">{job.period}</span>
          <h3 class="modal-title">{job.company}</h3>
          <p class="modal-sub">{job.position}</p>

          {job.bullets.length > 0 && (
            <ul class="modal-bullets">
              {job.bullets.map((b) => <li set:html={inlineMarkdown(b)} />)}
            </ul>
          )}

          {job.subGroups.map((sub) => (
            <div class="modal-subgroup">
              <h4 class="modal-subgroup-title">{sub.name}</h4>
              <ul class="modal-bullets">
                {sub.bullets.map((b) => <li set:html={inlineMarkdown(b)} />)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </dialog>
  );
})}

<!-- Project modals -->
{projects.map((proj) => {
  const modalId = `proj-${slugify(proj.name)}`;
  return (
    <dialog class="modal" id={modalId}>
      <div class="modal-inner">
        <button type="button" class="modal-close" aria-label="Close">×</button>
        <div class="modal-body">
          {proj.year && <span class="modal-eyebrow">{proj.year}</span>}
          <h3 class="modal-title">{proj.name}</h3>
          {proj.subtitle && <p class="modal-sub">{proj.subtitle}</p>}

          {proj.bullets.length > 0 && (
            <ul class="modal-bullets">
              {proj.bullets.map((b) => <li set:html={inlineMarkdown(b)} />)}
            </ul>
          )}
        </div>
      </div>
    </dialog>
  );
})}

<script>
  // Modal open/close handlers
  document.querySelectorAll<HTMLElement>('[data-modal]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const id = trigger.dataset.modal;
      if (!id) return;
      const dialog = document.getElementById(id) as HTMLDialogElement | null;
      if (dialog?.showModal) dialog.showModal();
      else if (dialog) dialog.setAttribute('open', '');
    });
  });

  // Close on close button or backdrop click
  document.querySelectorAll<HTMLDialogElement>('dialog.modal').forEach((dialog) => {
    const closeBtn = dialog.querySelector('.modal-close');
    closeBtn?.addEventListener('click', () => dialog.close());

    // Click on backdrop (outside .modal-inner) closes
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
